			}
			.zoom-value {
				font-size: 24rpx;
				color: #666666;
				min-width: 60rpx;
				text-align: center;
			}
		}
	}	
	
	.options-tab{
		width: 100%;
		display: flex;
		flex-direction: row;
		align-items: center;
