						position: absolute;
						top: 5rpx;
						right: 5rpx;
						width: 30rpx;
						height: 30rpx;
						background-color: white;
						border-radius: 50rpx;
						display: flex;
						justify-content: center;
						align-items: center;
						
						.icon {
							width: 24rpx;
							height: 24rpx;
						}
					}
				}
				.item.active{
					background-color: $uni-bg-color-blue;
				}
			}
		}
		
		.component{
			padding: 0 10rpx 60rpx 10rpx;
