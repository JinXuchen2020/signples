		position: fixed;
		left: -9999px;
		width: 1px;
		height: 1px;
		opacity: 0;
	}
	.flex-space-between {
		justify-content: space-between;
	}
    .canvas-component {
        width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 60px 20px 20px 20px;
		
		.canvas {
		    width: 100%;
		    height: 100%;
			background: #f0f0f0;
		}
    }
	.tools{
		// position: fixed;
		width: 100%;
		height: 180rpx;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		margin-top:10rpx;
		// left: 0;
		// bottom: 0;
		// z-index: 999;
		background-color: white;// $uni-bg-color;
		// padding: 24rpx;
		
		.pages{
			padding: 0 0 12rpx 0;
			.swiper-item{
				flex-direction: row;
				flex-wrap: wrap;
				align-items: center;
				justify-content: flex-start;
				width: 100%;
				.item{
					// width: 21%;
					height: 80rpx;
					flex: 1;
					background-color: #000000;
					flex-direction: row;
					align-items: center;
