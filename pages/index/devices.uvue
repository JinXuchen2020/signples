		font-size: 26rpx;
		color: #ff9800;
	}
	.batch-btn {
		padding: 12rpx 24rpx;
		border-radius: 8rpx;
		background-color: #ff9800;
	}
	.batch-btn-text {
		font-size: 24rpx;
		color: #ffffff;
	}
	.device-info {
		flex-direction: row;
		align-items: center;
	}
	.checkbox {
		width: 40rpx;
		height: 40rpx;
		border: 2rpx solid #cccccc;
		border-radius: 8rpx;
		margin-right: 24rpx;
		align-items: center;
		justify-content: center;
	}
	.checkbox.checked {
		border-color: $uni-color-primary;
		background-color: $uni-color-primary;
	}
	.checkbox-image {
		width: 28rpx;
		height: 28rpx;
	}
	.active-user{
		flex-direction: row;
		align-items: center;
		justify-content: center;
		
		.t{
			font-weight: bold;
			font-size: 28rpx;
		}
	}
	.wifi-info {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		padding: 24rpx 36rpx;
		border-bottom: 1px solid #eeeeee;
		
		.wifi-meta {
			flex-direction: row;
			align-items: center;
			justify-content: flex-start;
			.wifi-name{
				color: $uni-text-color;
				font-size: 28rpx;
			}
		}
		.scan {
			flex-direction: row;
			align-items: center;
			justify-content: flex-start;
